# =============================================================================
# CLERK Environment Configuration
# =============================================================================

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# LLM Provider (REQUIRED)
# -----------------------
# Your OpenAI API key for running reasoning kits
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Application (REQUIRED)
# ----------------------
# Secret key for signing session cookies and security
# IMPORTANT: Change this to a random string in production!
# Generate one with: openssl rand -hex 32
SECRET_KEY=generate-a-random-secret-key-here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# 
# CLERK supports two modes:
# 1. Local mode (default): Kits stored in reasoning_kits/ directory
# 2. Database mode: Uses PostgreSQL via Supabase for multi-user support
#
# For local development without Supabase, leave these empty.
# For production or multi-user setups, configure Supabase below.

# PostgreSQL Connection URL (required for database mode)
# Format: postgresql+asyncpg://user:password@host:port/database
# Example with Supabase pooler: postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://clerk:clerk@localhost:5432/clerk

# Direct connection URL for migrations (optional, recommended for Supabase)
# Uses port 5432 to bypass connection pooler for DDL operations
DATABASE_URL_DIRECT=

# =============================================================================
# SUPABASE CONFIGURATION (Optional - for cloud database)
# =============================================================================
# Found in Supabase Dashboard > Project Settings > API
#
# These enable cloud database features:
#   - Centralized storage of reasoning kits
#   - Version history for all kits
#   - Multi-user support with authentication
#   - Binary file support (PDF, XLSX, etc.)
#   - Full-text search across resources

# Supabase project URL
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key
# Used for public read operations and client-side access
SUPABASE_KEY=your-anon-key

# Supabase service role key
# Used for admin operations like creating storage buckets and running migrations
# Keep this secret! Never expose in client-side code.
SUPABASE_SERVICE_KEY=your-service-key

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Application Settings
# --------------------
# Log level: debug, info, warning, error
LOG_LEVEL=info

# Session cookie name
CLERK_SESSION_SECRET=clerk-session-secret-change-in-production

# Frontend Configuration
# ----------------------
# API URL for frontend to connect to backend
# Change if backend runs on different port
VITE_API_URL=http://localhost:8000

# Test Credentials (for development only)
# ---------------------------------------
CLERK_EMAIL=
CLERK_PASSWORD=

# =============================================================================
# QUICK START
# =============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env and set your OpenAI API key (REQUIRED):
#    OPENAI_API_KEY=sk-...
#
# 3. Generate a secret key:
#    openssl rand -hex 32
#
# 4. (Optional) Add Supabase credentials for database mode
#
# 5. Run setup:
#    ./scripts/setup.sh
#
# 6. Start development server:
#    npm run dev
#
# =============================================================================
